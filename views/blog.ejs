<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head') %>
 <title>Blog</title>
</head>
<body>
  <%- include('./partials/nav') %>
  <div class = "container mt-4">
    <h1><%= blog.title %></h1>
    <img src="<%= blog.coverImageURL %>" width = "200px"/>
    <pre class ="mt-3"><%= blog.body %></pre >

    <% if (user && blog.createdBy._id.toString() === user._id.toString()) { %>
      <form action="/blog/delete/<%= blog._id %>" method="POST">
        <button type="submit" class="btn btn-danger mt-2">
          Delete Blog
        </button>
      </form>
      <% } %>

  </div>
  <div class = "container mt-4">
    <img src ="<%= blog.createdBy.profileImageURL %>" width ="50px"> <%= blog.createdBy.fullName %>
  </div>
  <div class = "container mt-3">
    <h1>Comments (<%= comments.length %>)</h1>
    <% if (locals.user) { %>
     <form action = "/blog/comments/<%= blog._id %>" method = "post">
        <div class="mb-3">
          <input type="text" class="form-control" name = "content" placeholder ="Enter your Comment">
          <button type = "submit" class = "btn btn-sm btn-primary">Add</button>
        </div>
      </form>
    <% } %> 
    <div class = "mt-3">
        <% comments.forEach(comment => { %>
  <div>
    <img src ="<%= comment.createdBy.profileImageURL %>" width ="50px">
    <%= comment.createdBy.fullName %>:
    <pre><%= comment.content %></pre>

    <% if (user && comment.createdBy._id.toString() === user._id.toString()) { %>
      <form action="/blog/comment/delete/<%= comment._id %>" method="POST">
        <button type="submit" class="btn btn-danger btn-sm">
          Delete Comment
        </button>
      </form>
    <% } %>
  </div>
<% }) %>
      </div>
  </div>
  <%- include('./partials/scripts') %>
</body>
</html>